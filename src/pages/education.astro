    }
</style>

<script>
    // Smooth scroll for sidebar links
    document.querySelectorAll('.sidebar-nav a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const targetId = this.getAttribute('href');
            const targetElement = document.querySelector(targetId);
            if (targetElement) {
                const mainNav = document.querySelector('nav.nav');
                const mainNavHeight = mainNav ? mainNav.offsetHeight : 0;
                const scrollOffset = mainNavHeight + 32;

                const elementPosition = targetElement.getBoundingClientRect().top + window.pageYOffset;
                const offsetPosition = elementPosition - scrollOffset;

                window.scrollTo({
                    top: offsetPosition,
                    behavior: 'smooth'
                });

                document.querySelectorAll('.sidebar-nav a').forEach(link => link.classList.remove('active'));
                this.classList.add('active');
            }
        });
    });

    // Active link highlighting on scroll for sidebar
    const sections = document.querySelectorAll('.content-area section[id]');
    const sidebarLinks = document.querySelectorAll('.sidebar-nav a');
    const mainNavForActiveLink = document.querySelector('nav.nav'); 

    function changeLinkState() {
        let index = sections.length;
        const mainNavHeight = mainNavForActiveLink ? mainNavForActiveLink.offsetHeight : 0;
        const scrollOffset = mainNavHeight + 32; 

        while(--index >= 0 && window.pageYOffset + scrollOffset < sections[index].offsetTop) {}
        
        sidebarLinks.forEach((link) => link.classList.remove('active'));
        if (index >= 0 && sidebarLinks[index]) {
            sidebarLinks[index].classList.add('active');
        }
    }

    if (sections.length > 0 && sidebarLinks.length > 0) {
        changeLinkState(); 
        window.addEventListener('scroll', changeLinkState);
    }

    // Timeline item expansion
    const timelineItems = document.querySelectorAll('.timeline-item');
    timelineItems.forEach(item => {
        const content = item.querySelector('.timeline-content');
        if (content) {
            content.addEventListener('click', () => {
                item.classList.toggle('expanded');
            });
            content.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    item.classList.toggle('expanded');
                }
            });
        }
    });

    // Video loaded class
    const contentVideo = document.querySelector('.content-video');
    if (contentVideo instanceof HTMLVideoElement) {
        contentVideo.addEventListener('loadeddata', () => {
            contentVideo.classList.add('loaded');
        });
    }

    // Sticky sidebar logic
    const sidebar = document.querySelector('.sidebar-nav');
    const contentContainer = document.querySelector('.content-container');
    const contentArea = document.querySelector('.content-area');
    const mainNavForSticky = document.querySelector('nav.nav');

    if (sidebar && contentContainer && contentArea && mainNavForSticky) {
        let sidebarOriginalWidth = 0; 
        
        // Use columnGap from contentContainer, default to 0 if not found or not a number
        const getGridColumnGap = () => {
            if (!contentContainer) return 0;
            const gapValue = window.getComputedStyle(contentContainer).columnGap;
            const parsedGap = parseFloat(gapValue);
            return isNaN(parsedGap) ? 0 : parsedGap;
        };

        const updateSidebarOriginalWidth = () => {
            const wasFixed = sidebar.classList.contains('is-fixed');
            const wasBottomed = sidebar.classList.contains('is-bottomed');
            
            sidebar.classList.remove('is-fixed', 'is-bottomed');
            const prevPosition = sidebar.style.position;
            const prevWidth = sidebar.style.width;
            sidebar.style.position = ''; 
            sidebar.style.width = '';    

            sidebarOriginalWidth = sidebar.offsetWidth;

            sidebar.style.position = prevPosition;
            sidebar.style.width = prevWidth;
            if (wasFixed) sidebar.classList.add('is-fixed');
            if (wasBottomed) sidebar.classList.add('is-bottomed');
        };

        const mainNavHeight = mainNavForSticky.offsetHeight;
        const fixedTopValue = mainNavHeight + 32; 

        let initialSidebarScrollOffsetTop = 0;
        let initialSidebarLeftLayout = '0px'; 
        let initialContentAreaMarginLeft = '0px'; 
        let initialContentContainerPaddingLeft = '0px';
        let gridColumnGap = 0;


        const calculateInitialLayout = () => {
            sidebar.classList.remove('is-fixed', 'is-bottomed');
            sidebar.style.position = ''; sidebar.style.top = ''; sidebar.style.bottom = '';
            sidebar.style.left = ''; sidebar.style.width = '';

            updateSidebarOriginalWidth();

            initialContentAreaMarginLeft = window.getComputedStyle(contentArea).marginLeft;
            initialContentContainerPaddingLeft = window.getComputedStyle(contentContainer).paddingLeft;
            gridColumnGap = getGridColumnGap();

            const rect = sidebar.getBoundingClientRect();
            initialSidebarScrollOffsetTop = rect.top + window.scrollY;
            initialSidebarLeftLayout = rect.left + 'px'; 
            
        };

        calculateInitialLayout();
        window.addEventListener('resize', () => {
            calculateInitialLayout(); 
            handleStickyScroll(); 
        }); 
        
        function handleStickyScroll() {
            if (!contentArea || !contentContainer) return;

            if (window.innerWidth <= 768) { 
                sidebar.classList.remove('is-fixed', 'is-bottomed');
                sidebar.style.position = ''; sidebar.style.top = ''; sidebar.style.bottom = '';
                sidebar.style.left = ''; sidebar.style.width = '';
                return;
            }

            const scrollY = window.scrollY;
            const contentContainerRect = contentContainer.getBoundingClientRect();
            const sidebarHeight = sidebar.offsetHeight;

            const stickPoint = initialSidebarScrollOffsetTop - fixedTopValue;
            const unstickBottomPointDoc = (contentContainerRect.top + scrollY + contentContainer.offsetHeight) - sidebarHeight;
            
            if (scrollY > stickPoint && (scrollY + fixedTopValue) < unstickBottomPointDoc) { 
                if (!sidebar.classList.contains('is-fixed')) {
                    sidebar.classList.add('is-fixed');
                    sidebar.classList.remove('is-bottomed');
                    sidebar.style.position = 'fixed';
                    sidebar.style.width = sidebarOriginalWidth + 'px';
                    sidebar.style.left = initialSidebarLeftLayout; 
                    sidebar.style.top = fixedTopValue + 'px';
                    sidebar.style.bottom = 'auto';
                }
            } else if ((scrollY + fixedTopValue) >= unstickBottomPointDoc) { 
                if (!sidebar.classList.contains('is-bottomed')) {
                    sidebar.classList.remove('is-fixed');
                    sidebar.classList.add('is-bottomed');
                    sidebar.style.position = 'absolute';
                    sidebar.style.width = sidebarOriginalWidth + 'px';
                    sidebar.style.top = (contentContainer.offsetHeight - sidebarHeight - parseFloat(window.getComputedStyle(contentContainer).paddingBottom || '0')) + 'px';
                    sidebar.style.left = initialContentContainerPaddingLeft; 
                    sidebar.style.bottom = 'auto';
                }
            } else { 
                if (sidebar.classList.contains('is-fixed') || sidebar.classList.contains('is-bottomed')) {
                    sidebar.classList.remove('is-fixed', 'is-bottomed');
                    sidebar.style.position = ''; 
                    sidebar.style.top = ''; sidebar.style.bottom = '';
                    sidebar.style.left = ''; sidebar.style.width = '';
                }
            }
        }
        window.addEventListener('scroll', handleStickyScroll);
        handleStickyScroll();

    }
</script> 